---
const title = "Hi world";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root {
        font-family: Arial, sans-serif;
        color-scheme: light;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #f4f7fb;
        color: #1f2937;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 5vw, 4rem);
      }
    </style>
  </head>
  <body>
    <h1>{title}</h1>
  </body>
</html>
