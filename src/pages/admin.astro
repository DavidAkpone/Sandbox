---
import { adminDemoCredentials } from "../data/forum";

const title = "Admin Login | Volvo CE Forum";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        color-scheme: light;
        --bg: #f3f0e8;
        --panel: rgba(255, 255, 255, 0.86);
        --ink: #1f2a2e;
        --muted: #5b666e;
        --line: rgba(31, 42, 46, 0.12);
        --accent: #f4b400;
        --forest: #2f5d50;
        --shadow: 0 24px 60px rgba(31, 42, 46, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(244, 180, 0, 0.16), transparent 28%),
          radial-gradient(circle at top right, rgba(47, 93, 80, 0.15), transparent 24%),
          linear-gradient(180deg, #ebe6da 0%, var(--bg) 55%, #f7f4ed 100%);
      }

      .panel {
        width: min(520px, calc(100% - 1.5rem));
        padding: 1.5rem;
        border-radius: 28px;
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.65);
        box-shadow: var(--shadow);
      }

      h1 {
        margin-top: 0;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      .demo {
        padding: 0.85rem 1rem;
        border-radius: 18px;
        background: rgba(47, 93, 80, 0.06);
        border: 1px solid rgba(47, 93, 80, 0.12);
        margin-bottom: 1rem;
      }

      form {
        display: grid;
        gap: 0.85rem;
      }

      label {
        display: grid;
        gap: 0.4rem;
        font-weight: 700;
      }

      input {
        width: 100%;
        border: 1px solid rgba(31, 42, 46, 0.14);
        border-radius: 16px;
        padding: 0.9rem 1rem;
        font: inherit;
        background: rgba(255, 255, 255, 0.94);
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 0.5rem;
      }

      button,
      .back {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 999px;
        padding: 0.9rem 1.2rem;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
      }

      button {
        background: linear-gradient(135deg, var(--accent), #ffd86b);
        color: #3a2a00;
      }

      .back {
        background: rgba(31, 42, 46, 0.08);
        color: var(--ink);
      }

      .status {
        min-height: 1.4rem;
        color: var(--forest);
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main class="panel">
      <h1>Admin Login</h1>
      <p>
        This is a demo-only admin sign-in. It creates the look and flow of an admin entry point,
        but it does not provide real authentication or protected access.
      </p>

      <div class="demo">
        Demo credentials: <strong>{adminDemoCredentials.username}</strong> /
        <strong>{adminDemoCredentials.password}</strong>
      </div>

      <form id="admin-form">
        <label>
          Username
          <input id="username" name="username" type="text" value={adminDemoCredentials.username} />
        </label>

        <label>
          Password
          <input id="password" name="password" type="password" value={adminDemoCredentials.password} />
        </label>

        <div class="actions">
          <button type="submit">Demo sign in</button>
          <a class="back" href={`${base}/`}>Back to forum</a>
        </div>

        <div class="status" id="status"></div>
      </form>
    </main>

    <script>
      const form = document.querySelector("#admin-form");
      const status = document.querySelector("#status");

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        localStorage.setItem("volvo-ce-forum:admin-demo", "signed-in");
        status.textContent = "Demo admin session activated in this browser.";
      });
    </script>
  </body>
</html>
